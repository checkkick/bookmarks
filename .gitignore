# Environments and Dependencies
# ==========================================
# Virtual environments
.venv/
venv/
env/
ENV/
pyenv/

# Pipenv or Poetry files (if you prefer locking dependencies without local exports)
.poetry/

# Secret / Environment variable files
.env
.secrets

