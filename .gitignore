# ==========================================
# Python Byte-compiled / optimized files
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Django Specific Files & Folders
# ==========================================
# Local database (SQLite)
*.sqlite3

# User-uploaded media and collected static assets
media/
staticfiles/

# Logs
*.log

